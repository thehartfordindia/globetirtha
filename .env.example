# Local / deployment environment variables
WEBSITE_URL=http://localhost:8787
WEBHOOK_SECRET=change-me
PORT=8787

# Provider selection (optional): sendgrid|webhook and twilio|webhook
EMAIL_PROVIDER=
SMS_PROVIDER=

# Direct email provider (SendGrid)
SENDGRID_API_KEY=
EMAIL_FROM=

# Direct SMS provider (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Webhook fallback (use if you route through your own gateway service)
EMAIL_WEBHOOK_URL=
SMS_WEBHOOK_URL=
